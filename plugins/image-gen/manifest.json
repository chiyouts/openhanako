{
  "id": "image-gen",
  "name": "Image Generation",
  "version": "0.1.0",
  "description": "Image generation for OpenAI-compatible and Volcengine providers",
  "trust": "full-access",
  "hidden": true,
  "contributes": {
    "configuration": {
      "properties": {
        "defaultImageModel": {
          "type": "object",
          "title": "Default image model",
          "properties": {
            "id": { "type": "string" },
            "provider": { "type": "string" }
          }
        },
        "providerDefaults": {
          "type": "object",
          "title": "Per-provider defaults"
        },
        "outputDir": {
          "type": "string",
          "title": "Generated media output directory"
        },
        "outputDirHistory": {
          "type": "array",
          "title": "Historical generated media directories",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
